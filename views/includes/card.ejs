<div class="card gallery-card">
    <% if (typeof imgpath !== 'undefined' && imgpath) { %>
        <img src = "<%= imgpath %>" alt = "<%= typeof title !== 'undefined' && title ? title : 'Gallery Image' %>">
    <% } else { %>
        <img src = "/images/placeholder.jpg" alt = "<%= typeof title !== 'undefined' && title ? title : 'Gallery Image' %>">
    <% } %>

    <% if (typeof title !== 'undefined' && title) { %>
        <h2 class="gallery-card-body"><%=title%></h2>
    <% } else { %>
        <h2 class="gallery-card-body">
            Art by Katie Frymire
        </h2>
    <% } %>
</div>